font-family = JetBrainsMono Nerd Font
font-size = 12

theme = Atom One Dark

# gtk-tabs-location = bottom

window-decoration = false
maximize = true
# window-padding-color = extend

keybind = ctrl+shift+t=unbind
keybind = ctrl+shift+n=unbind
keybind = ctrl+shift+o=unbind
keybind = ctrl+shift+q=unbind
keybind = ctrl+shift+p=unbind
keybind = ctrl+shift+h=unbind
keybind = ctrl+shift+b=unbind
keybind = ctrl+shift+g=unbind
keybind = ctrl+shift+slash=unbind

keybind = super+shift+t=new_tab
keybind = super+shift+n=new_window
keybind = super+shift+o=new_split:right
keybind = super+shift+q=quit
keybind = super+shift+p=toggle_command_palette
